{
	"name": "@palot/events",
	"version": "0.0.1",
	"private": true,
	"license": "MIT",
	"description": "Typed event bus, PalotEvent channels, replay utilities for the Palot agent platform core. Pure TS (no React, no providers, no Electron).",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"build:types": "tsc",
		"check-types": "tsgo --noEmit",
		"test": "bun test",
		"lint": "biome check .",
		"clean": "rm -rf dist node_modules .turbo"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.8.3"
	}
}
