{
	"name": "@palot/ipc-contracts",
	"version": "0.0.1",
	"private": true,
	"license": "MIT",
	"description": "Single source of truth for Palot IPC channel names, request/response payload types, and validation schemas. Used to keep main/preload/renderer in sync.",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"build:types": "tsc",
		"check-types": "tsgo --noEmit",
		"test": "bun test",
		"lint": "biome check .",
		"clean": "rm -rf dist node_modules .turbo"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.8.3"
	}
}
