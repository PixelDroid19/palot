{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noEmit": true,
		// Lit decorator support (new + legacy for packages/lit-components which uses experimentalDecorators + useDefineForClassFields).
		// Required because paths map @palot/lit-* directly to src (dev/hot reload + typecheck consume source).
		// Matches packages/lit-components/tsconfig.json .
		"experimentalDecorators": true,
		"useDefineForClassFields": true,
		"paths": {
			"@/*": ["./src/renderer/*"],
			"@/features/automations": ["./src/renderer/features/automations/index.ts"],
			"@/features/settings": ["./src/renderer/features/settings/index.ts"],
			"@/features/onboarding": ["./src/renderer/features/onboarding/index.ts"],
			"@/features/chat": ["./src/renderer/features/chat/index.ts"],
			"@/components/public": ["./src/renderer/components/public.ts"],
			"@desktop/shared": ["./src/shared/index.ts"],
			"@desktop/shared/*": ["./src/shared/*"],
			"@desktop/preload": ["./src/preload/public-api.ts"],
			"@desktop/preload/*": ["./src/preload/*"],
			"@palot/ui/*": ["../../packages/ui/src/*"],
			"@palot/tokens": ["../../packages/tokens/src/index.ts"],
			"@palot/tokens/*": ["../../packages/tokens/src/*"],
			"@palot/lit-components": ["../../packages/lit-components/src/index.ts"],
			"@palot/lit-components/*": ["../../packages/lit-components/src/*"],
			"@palot/lit-styles": ["../../packages/lit-styles/src/index.ts"],
			"@palot/lit-styles/*": ["../../packages/lit-styles/src/*"],
			"@palot/events": ["../../packages/events/src/index.ts"],
			"@palot/events/*": ["../../packages/events/src/*"],
			"@palot/core": ["../../packages/core/src/index.ts"],
			"@palot/core/*": ["../../packages/core/src/*"],
			"@palot/agent-adapter-opencode": ["../../packages/agent-adapter-opencode/src/index.ts"],
			"@palot/agent-adapter-opencode/*": ["../../packages/agent-adapter-opencode/src/*"],
			"@palot/agent-harness": ["../../packages/agent-harness/src/index.ts"],
			"@palot/agent-harness/*": ["../../packages/agent-harness/src/*"],
			"@palot/ipc-contracts": ["../../packages/ipc-contracts/src/index.ts"],
			"@palot/ipc-contracts/*": ["../../packages/ipc-contracts/src/*"]
		}
	},
	"include": [
		"src/main/**/*.ts",
		"src/preload/**/*.ts",
		"src/preload/**/*.d.ts",
		"src/shared/**/*.ts",
		"src/renderer/**/*.ts",
		"src/renderer/**/*.tsx",
		"test/**/*.ts",
		"vite-aliases.ts",
		"src/custom-elements.d.ts"
	],
	"exclude": ["node_modules", "dist", "out", "release"]
}
